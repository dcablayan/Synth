# Synth Environment Variables
# Copy this file to .env.local and fill in your values.

# AI Provider (optional — if not set, mock mode is used)
# OPENAI_API_KEY=sk-...

# Optional: Use any OpenAI-compatible provider (Together, Groq, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use (default: gpt-4o)
# OPENAI_MODEL=gpt-4o
